{
  "app-id": "io.github.josephnathanie.BudgetWiseAI",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "23.08",
  "command": "budgetwise-ai",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=xdg-config/BudgetWiseAI:create"
  ],
  "modules": [
    {
      "name": "budgetwise-ai",
      "buildsystem": "simple",
      "build-commands": [
        "npm install",
        "npm run build",
        "cp -r dist/ /app/share/budgetwise-ai/",
        "install -Dm755 launch-script.sh /app/bin/budgetwise-ai"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com",
          "branch": "main"
        },
        {
          "type": "script",
          "dest-filename": "launch-script.sh",
          "commands": [
            "#!/bin/sh",
            "exec electron /app/share/budgetwise-ai/dist/main.js \"$@\""
          ]
        }
      ]
    }
  ]
}

